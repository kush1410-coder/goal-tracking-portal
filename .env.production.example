# Vercel Production Environment Variables
# Copy these values to Vercel Dashboard > Project Settings > Environment Variables

# Database (Required - Choose one)
# For PostgreSQL (Supabase/Neon):
DATABASE_URL=postgresql://user:password@host:5432/database

# For MongoDB Atlas:
# DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/database

# Application
NODE_ENV=production
PORT=3000

# Session & Security (Generate a strong random string)
SESSION_SECRET=your-very-long-random-secret-key-here-min-32-chars

# Backend URL (Set after first deployment)
BACKEND_URL=https://your-project.vercel.app

# Notification Services (if using email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Microsoft Teams Webhook (if using)
TEAMS_WEBHOOK_URL=https://outlook.webhook.office.com/webhookb2/...

# Admin Configuration
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-in-production
